# Sentinel environment configuration

SENTINEL_PORT=8080
SENTINEL_ALGORITHM=token_bucket
SENTINEL_RATE_LIMIT=10
SENTINEL_REFILL_RATE=1
SENTINEL_WINDOW_SEC=60

# Set true to use Redis-backed distributed limiting (required for multi-instance)
SENTINEL_USE_REDIS=false

SENTINEL_REDIS_URL=redis://localhost:6379
SENTINEL_REDIS_FAILURE_MODE=closed

SENTINEL_ADMIN_API_KEY=dev-admin-key
SENTINEL_INSTANCE_ID=gateway-1

# Adaptive rate limiting (AIMD — tightens limits when latency spikes)
SENTINEL_ADAPTIVE_ENABLED=false
SENTINEL_ADAPTIVE_LATENCY_MS=100
SENTINEL_ADAPTIVE_MIN_MULTIPLIER=0.25
SENTINEL_ADAPTIVE_ADJUST_SEC=5

# Multi-region key prefix (readiness — single Redis for MVP)
SENTINEL_REGION=local

# Per-route limits: route:capacity:refill_rate
# SENTINEL_ROUTE_LIMITS=/api/test:5:1

GRAFANA_PASSWORD=admin
POSTGRES_PASSWORD=sentinel
