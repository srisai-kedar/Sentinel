      "id": 1,
      "targets": [{ "expr": "sum(rate(sentinel_requests_total[1m]))", "legendFormat": "req/s" }],
      "title": "Request Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "id": 2,
      "targets": [{ "expr": "sum(rate(sentinel_blocked_requests_total[1m]))", "legendFormat": "blocked/s" }],
      "title": "Blocked Requests",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "id": 3,
      "targets": [{ "expr": "histogram_quantile(0.99, sum(rate(sentinel_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p99" }],
      "title": "Request Latency p99",
